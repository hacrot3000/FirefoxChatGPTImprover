{
    "version": "2.0.0",
    "_comment": "FirefoxChatImprover build tasks. Phase-specific tests are consolidated into tools/test_firefox_addon.sh instead of adding one menu item per phase. Release workflow: Build Release (step 1) → Publish Release (step 2: tag + push to remote).",
    "tasks": [
        {
            "label": "Patchs: Run Python Patch",
            "type": "shell",
            "command": "./tools/run_python_patches.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Patchs: Run Python Patch + Test",
            "type": "shell",
            "command": "./tools/run_python_patches.sh && ./tools/test_firefox_addon.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Firefox Add-on: Build",
            "type": "shell",
            "command": "./tools/build_firefox_addon.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },        
        {
            "label": "Git: Add, Commit and Push",
            "type": "shell",
            "command": "./tools/git_commit_push.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Zip staged changes",
            "type": "shell",
            "command": "./zip_staged_changes.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Firefox Add-on: Setup Dev Environment",
            "type": "shell",
            "command": "./tools/setup_firefox_addon_dev.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Firefox Add-on: Run Dev (Auto Reload)",
            "type": "shell",
            "command": "./tools/run_firefox_addon_dev.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Firefox Add-on: Lint",
            "type": "shell",
            "command": "./tools/lint_firefox_addon.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Firefox Add-on: Build Release",
            "detail": "Chạy tests, lint rồi build unsigned .zip artifact vào dist/releases/<version>/ (chỉ local, không publish)",
            "type": "shell",
            "command": "./tools/build_firefox_addon.sh",
            "args": ["--overwrite"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Firefox Add-on: Build Release + Publish to GitHub",
            "detail": "Chạy tests, lint, build rồi tự động tạo GitHub Release và upload .zip (yêu cầu gh auth login)",
            "type": "shell",
            "command": "./tools/build_firefox_addon.sh",
            "args": ["--overwrite", "--publish"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },

        {
            "label": "Firefox Add-on: Publish Release (Tag + Push)",
            "detail": "Build release → tạo git annotated tag v<version> → commit → push lên remote để tải về cài Firefox",
            "type": "shell",
            "command": "./tools/release_publish.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
