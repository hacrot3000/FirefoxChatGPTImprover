{
  "manifest_version": 3,
  "name": "FirefoxChatImprover",
  "version": "0.1.0",
  "description": "Private Firefox sidebar helper for manually activated AI chat tabs.",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-chat-improver@duongtc.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Mở và kích hoạt FirefoxChatImprover"
  },
  "background": {
    "scripts": [
      "shared/protocol.js",
      "background/background.js"
    ]
  },
  "sidebar_action": {
    "default_title": "FirefoxChatImprover",
    "default_panel": "sidebar/sidebar.html",
    "open_at_install": false
  }
}
