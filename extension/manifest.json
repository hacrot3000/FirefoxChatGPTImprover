{
  "manifest_version": 3,
  "name": "Firefox ChatAI Assistant",
  "version": "0.22.0",
  "description": "Private Firefox sidebar helper with independent multi-tab automation, verified working-session restore, managed download relocation, safe local commands and file-backed full terminal logs.",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-chat-assistant@duongtc.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sessions",
    "notifications",
    "nativeMessaging",
    "downloads",
    "webRequest",
    "webRequestBlocking"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_title": "Open and activate Firefox ChatAI Assistant",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "background": {
    "scripts": [
      "shared/protocol.js",
      "shared/settings.js",
      "shared/local_actions.js",
      "shared/settings_snapshots.js",
      "shared/working_session.js",
      "shared/recovery.js",
      "shared/support_bundle.js",
      "background/background.js"
    ]
  },
  "sidebar_action": {
    "default_title": "Firefox ChatAI Assistant",
    "default_panel": "sidebar/sidebar.html",
    "open_at_install": false
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
