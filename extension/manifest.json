{
  "manifest_version": 3,
  "name": "FirefoxChatImprover",
  "version": "0.5.1",
  "description": "Private Firefox sidebar helper with independent multi-tab monitoring, target automation, per-tab alerts and activity logs.",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-chat-improver@duongtc.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sessions",
    "notifications"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_title": "Mở và kích hoạt FirefoxChatImprover",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "background": {
    "scripts": [
      "shared/protocol.js",
      "shared/settings.js",
      "background/background.js"
    ]
  },
  "sidebar_action": {
    "default_title": "FirefoxChatImprover",
    "default_panel": "sidebar/sidebar.html",
    "open_at_install": false
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
